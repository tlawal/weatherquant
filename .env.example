# ─── Database ────────────────────────────────────────────────────────────────
# Postgre SQL (Railway): postgresql+asyncpg://user:pass@host:5432/dbname
# SQLite (local dev):   sqlite+aiosqlite:////tmp/weatherquant.db
DATABASE_URL=sqlite+aiosqlite:////tmp/weatherquant.db

# ─── Timezone ────────────────────────────────────────────────────────────────
TZ=America/New_York

# ─── Service mode ────────────────────────────────────────────────────────────
# "api" → serves FastAPI + dashboard (port 8000)
# "worker" → runs scheduler + auto-trader
SERVICE_TYPE=api

# ─── Polymarket CLOB ─────────────────────────────────────────────────────────
POLYMARKET_PRIVATE_KEY=0x_your_private_key_here
FUNDER_ADDRESS=0x_your_funder_address_here
POLYMARKET_HOST=https://clob.polymarket.com
CHAIN_ID=137

# ─── Security ────────────────────────────────────────────────────────────────
# Strong random string for dashboard API calls
ADMIN_TOKEN=change_me_strong_random_string

# Passphrase required to complete 2-step arming
ARMING_SECRET=change_me_second_factor

# ─── Trading Safety ──────────────────────────────────────────────────────────
AUTO_TRADE_DEFAULT=off
BANKROLL_CAP=10.0
MAX_POSITION_PCT=0.10
MAX_DAILY_LOSS=3.0
MIN_TRUE_EDGE=0.10
MIN_LIQUIDITY_SHARES=10.0
MAX_POSITIONS_PER_EVENT=2
TRADING_WINDOW_CLOSE_ET=19
TRADING_FORCE_DISABLE_ET=21
WU_STALE_TTL_SECONDS=7200

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=true

# ─── Market Context LLM (optional) ───────────────────────────────────────────
# Supported providers: openai, anthropic
MARKET_CONTEXT_LLM_PROVIDER=
MARKET_CONTEXT_LLM_MODEL=
MARKET_CONTEXT_LLM_API_KEY=
MARKET_CONTEXT_LLM_BASE_URL=
MARKET_CONTEXT_LLM_TIMEOUT_SECONDS=45
